{
  "name": "escritorio-alv-backend",
  "version": "1.0.0",
  "description": "Backend do Sistema Fiscal Alvorada - gerador de NFS-e e boletos",
  "main": "dist/server.js",
  "scripts": {
    "start": "tsx watch ./src/server.ts",
    "build": "npx tsc",
    "serve": "node ./dist/server.js",
    "seed": "tsx ./src/scripts/seed.ts",
    "migration:run": "tsx ./src/run-migrations.ts"
  },
  "keywords": ["nfse", "boleto", "fiscal"],
  "author": "Escritório Alvorada Contabilidade",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.3",
    "reflect-metadata": "^0.2.2",
    "tsx": "^4.21.0",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.18.10",
    "typescript": "^5.6.3"
  }
}
